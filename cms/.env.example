# Lokale Entwicklung (SQLite)
DATABASE_URL=file:./cms.db

# Produktion (PostgreSQL auf Railway/Vercel) – DATABASE_ADAPTER auf postgres setzen:
# DATABASE_ADAPTER=postgres
# DATABASE_URL=postgresql://user:password@host:5432/dbname

PAYLOAD_SECRET=change-me-to-a-long-random-string
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# CORS: URLs der Website (für Live-Abruf der Fotos im Browser)
# Lokal:
CORS_ORIGINS=http://localhost:4321
# Produktion (Vercel CMS-Projekt):
# CORS_ORIGINS=https://svenmagnus.com,https://www.svenmagnus.com,https://photographer-portfolio-web.vercel.app
# Optional: weitere Frontend-URLs
# WEB_ORIGINS=

# Vercel Blob Storage (Produktion auf Vercel – optional lokal)
# BLOB_READ_WRITE_TOKEN=vercel_blob_...

# E-Mail für „Forgot password“ (z. B. Strato SMTP)
# SMTP_HOST=smtp.strato.de
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=mail@svenmagnus.com
# SMTP_PASS=dein-postfach-passwort
# SMTP_FROM_ADDRESS=mail@svenmagnus.com
# SMTP_FROM_NAME=Sven Magnus Portfolio
