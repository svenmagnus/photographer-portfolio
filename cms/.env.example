# Lokale Entwicklung (SQLite)
DATABASE_URL=file:./cms.db

# Produktion (PostgreSQL auf Railway/Vercel) – DATABASE_ADAPTER auf postgres setzen:
# DATABASE_ADAPTER=postgres
# DATABASE_URL=postgresql://user:password@host:5432/dbname

PAYLOAD_SECRET=change-me-to-a-long-random-string
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# CORS: URL des Astro-Frontends
CORS_ORIGINS=http://localhost:4321,https://your-domain.com

# Vercel Blob Storage (Produktion auf Vercel – optional lokal)
# BLOB_READ_WRITE_TOKEN=vercel_blob_...
