{
  "name": "cms",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run generate:importmap && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --port 3000",
    "devsafe": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true; rm -rf .next node_modules/.cache 2>/dev/null; cross-env NODE_OPTIONS=--no-deprecation next dev --port 3000",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.2",
    "@payloadcms/db-sqlite": "3.85.2",
    "@payloadcms/email-nodemailer": "^3.85.2",
    "@payloadcms/next": "3.85.2",
    "@payloadcms/richtext-lexical": "3.85.2",
    "@payloadcms/storage-vercel-blob": "3.85.2",
    "@payloadcms/ui": "3.85.2",
    "@vercel/blob": "^2.6.1",
    "cross-env": "^7.0.3",
    "graphql": "^16.12.0",
    "next": "15.4.11",
    "payload": "3.85.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.8.3"
  }
}
