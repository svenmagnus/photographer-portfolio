---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
---

<Layout title="Store — Sven Magnus Hanefeld">
  <main>
    <Header />
    <section class="max-w-2xl mx-auto px-6 py-16 text-portfolio-muted leading-relaxed text-center text-[13px]">
      <h2 class="text-2xl text-portfolio-black mb-6">Store</h2>
      <p>Prints and store links can be added here.</p>
      <p class="mt-8">
        <a href="/" class="underline hover:text-portfolio-black">← Back to portfolio</a>
      </p>
    </section>
  </main>
</Layout>
