---
export const prerender = false

import BlogPostPage from '../../../components/pages/BlogPostPage.astro'

const blogSlug = Astro.params.slug
const postSlug = Astro.params.postSlug

if (!blogSlug || !postSlug) {
  return new Response(null, { status: 404, statusText: 'Not Found' })
}

---

<BlogPostPage locale="en" blogSlug={blogSlug} postSlug={postSlug} />
