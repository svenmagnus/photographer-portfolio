---
export const prerender = false

import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import BlockRenderer from '../components/blocks/BlockRenderer.astro'
import Lightbox from '../components/Lightbox.astro'
import { fetchPageBySlug } from '../lib/pages'
import { fetchSiteSettings } from '../lib/siteSettings'
import { buildNavigation } from '../lib/navigation'

const slug = Astro.params.slug

if (!slug) {
  return new Response(null, { status: 404, statusText: 'Not Found' })
}

const page = await fetchPageBySlug(slug)

if (!page) {
  return new Response(null, { status: 404, statusText: 'Not Found' })
}
const settings = await fetchSiteSettings()
const navItems = buildNavigation(settings)

const pageTitle = page.metaTitle || `${page.title} — ${settings.photographerName || 'Sven Magnus Hanefeld'}`
const description = page.metaDescription || settings.metaDescription || page.title
---

<Layout title={pageTitle} description={description}>
  <main class="min-h-screen bg-white pb-16">
    <Header activeSlug={page.slug} navItems={navItems} settings={settings} />
    <BlockRenderer blocks={page.layout} pageType={page.pageType} settings={settings} />
    <Lightbox />
  </main>
</Layout>
