---
export const prerender = false

import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import BlockRenderer from '../components/blocks/BlockRenderer.astro'
import BlogPostList from '../components/blog/BlogPostList.astro'
import Lightbox from '../components/Lightbox.astro'
import { fetchPageBySlug, fetchNavigationPages } from '../lib/pages'
import { fetchBlogPostsForPage } from '../lib/blogPosts'
import { fetchSiteSettings } from '../lib/siteSettings'
import { fetchMainMenu } from '../lib/mainMenu'
import { buildNavigation } from '../lib/navigation'

const slug = Astro.params.slug

if (!slug) {
  return new Response(null, { status: 404, statusText: 'Not Found' })
}

const [page, settings, mainMenu, navPages] = await Promise.all([
  fetchPageBySlug(slug),
  fetchSiteSettings(),
  fetchMainMenu(),
  fetchNavigationPages(),
])

const blogPosts =
  page?.pageType === 'blog' ? await fetchBlogPostsForPage(page.slug) : []

if (!page) {
  return new Response(null, { status: 404, statusText: 'Not Found' })
}

const navItems = buildNavigation(settings, navPages, mainMenu.items)
const activeCategory =
  page.pageType === 'gallery' ? page.galleryCategory || page.slug : undefined

const pageTitle = page.metaTitle || `${page.title} — ${settings.photographerName || 'Sven Magnus Hanefeld'}`
const description = page.metaDescription || settings.metaDescription || page.title
---

<Layout title={pageTitle} description={description}>
  <main class="min-h-screen bg-white pb-16">
    <Header
      activeSlug={page.pageType !== 'gallery' ? page.slug : undefined}
      activeCategory={activeCategory}
      navItems={navItems}
      settings={settings}
    />
    {
      page.pageType === 'blog' ? (
        <>
          <BlockRenderer blocks={page.layout} pageType={page.pageType} settings={settings} />
          <BlogPostList posts={blogPosts} blogSlug={page.slug} />
        </>
      ) : (
        <BlockRenderer blocks={page.layout} pageType={page.pageType} settings={settings} />
      )
    }
    <Lightbox />
  </main>
</Layout>
