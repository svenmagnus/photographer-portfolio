---
import type { BlogPost } from '../../lib/blogPosts'
import { getBlogPostListImage } from '../../lib/blogPostMedia'
import { getBlogPostIntro } from '../../lib/blogPostIntro'
import { getMediaUrl } from '../../lib/photoLoader'
import type { Locale } from '../../i18n/locale'
import { DEFAULT_LOCALE, localePath } from '../../i18n/locale'
import { dateLocale, t } from '../../i18n/messages'

interface Props {
  posts: BlogPost[]
  blogSlug: string
  locale?: Locale
}

const { posts, blogSlug, locale = DEFAULT_LOCALE } = Astro.props

function formatPostDate(value?: string | null): string | null {
  if (!value) return null

  const date = new Date(value)
  if (Number.isNaN(date.getTime())) return null

  return new Intl.DateTimeFormat(dateLocale(locale), {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date)
}
---

<section class="blog-post-list" aria-label="Blog-Beiträge">
  {
    posts.length === 0 ? (
      <p class="blog-post-empty">{t(locale, 'blogEmpty')}</p>
    ) : (
      <ul class="blog-post-rows">
        {
          posts.map((post) => {
            const postUrl = localePath(`/${blogSlug}/${post.slug}`, locale)
            const listImage = getBlogPostListImage(post)
            const imageUrl = getMediaUrl(listImage)
            const dateLabel = formatPostDate(post.publishedAt)
            const { intro, showReadMore } = getBlogPostIntro(post)

            return (
              <li class="blog-post-card">
                {
                  imageUrl ? (
                    <a href={postUrl} class="blog-post-image-link">
                      <img
                        src={imageUrl}
                        alt={listImage?.alt || post.title}
                        loading="lazy"
                        decoding="async"
                        class="blog-post-image"
                      />
                    </a>
                  ) : null
                }

                <div class="blog-post-body">
                  <h2 class="blog-post-title">
                    <a href={postUrl}>{post.title}</a>
                  </h2>
                  {dateLabel ? <p class="blog-post-date">{dateLabel}</p> : null}
                  {intro ? <p class="blog-post-intro">{intro}</p> : null}
                  {
                    showReadMore ? (
                      <a href={postUrl} class="blog-post-read-more">
                        {t(locale, 'blogReadMore')}
                      </a>
                    ) : null
                  }
                </div>
              </li>
            )
          })
        }
      </ul>
    )
  }
</section>

<style>
  .blog-post-list {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .blog-post-empty {
    margin: 0;
    padding: 3rem 0;
    text-align: center;
    font-size: 15px;
    color: #666;
  }

  .blog-post-rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .blog-post-card {
    margin: 0 0 3rem;
    padding: 0 0 3rem;
    border-bottom: 1px solid #e8e8e8;
  }

  .blog-post-card:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .blog-post-image-link {
    display: block;
    margin-bottom: 1.25rem;
    text-decoration: none;
  }

  .blog-post-image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .blog-post-body {
    font-family: Georgia, 'Times New Roman', serif;
  }

  .blog-post-title {
    margin: 0;
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 400;
    line-height: 1.35;
  }

  .blog-post-title a {
    color: #000;
    text-decoration: none;
  }

  .blog-post-title a:hover {
    opacity: 0.65;
  }

  .blog-post-date {
    margin: 0.45rem 0 0;
    font-size: 13px;
    line-height: 1.4;
    color: #888;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .blog-post-intro {
    margin: 1rem 0 0;
    font-size: 15px;
    line-height: 1.75;
    color: #333;
  }

  .blog-post-read-more {
    display: inline-block;
    margin-top: 0.85rem;
    font-size: 14px;
    line-height: 1.4;
    color: #000;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .blog-post-read-more:hover {
    opacity: 0.65;
  }
</style>
