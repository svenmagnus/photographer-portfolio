---
import Layout from '../../layouts/Layout.astro'
import Header from '../Header.astro'
import PhotoGrid from '../PhotoGrid.astro'
import Lightbox from '../Lightbox.astro'
import CategoryFilter from '../CategoryFilter.astro'
import type { Locale } from '../../i18n/locale'
import { fetchSiteSettings } from '../../lib/siteSettings'
import { fetchMainMenu } from '../../lib/mainMenu'
import { fetchNavigationPages } from '../../lib/pages'
import { buildNavigation } from '../../lib/navigation'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const activeCategory = Astro.url.searchParams.get('category') ?? 'hollywood'

const [settings, mainMenu, navPages] = await Promise.all([
  fetchSiteSettings(locale),
  fetchMainMenu(locale),
  fetchNavigationPages(locale),
])

const navItems = buildNavigation(settings, navPages, mainMenu.items, locale)
const pageTitle = `${settings.photographerName || 'Sven Magnus Hanefeld'} — ${settings.photographerTitle || 'Photographer'}`
---

<Layout title={pageTitle} description={settings.metaDescription || undefined} locale={locale}>
  <main class="min-h-screen bg-white">
    <Header activeCategory={activeCategory} navItems={navItems} settings={settings} locale={locale} />
    <PhotoGrid />
    <Lightbox />
    <CategoryFilter />
  </main>
</Layout>
