---
import { PHOTO_CATEGORIES, STATIC_NAV_LINKS } from '../lib/categories'

interface Props {
  activeCategory?: string
}

const { activeCategory } = Astro.props

const photographerName = import.meta.env.PUBLIC_PHOTOGRAPHER_NAME || 'Sven Magnus Hanefeld'
const photographerTitle = import.meta.env.PUBLIC_PHOTOGRAPHER_TITLE || 'Photographer'
const instagramUrl = import.meta.env.PUBLIC_INSTAGRAM_URL || '#'
const facebookUrl = import.meta.env.PUBLIC_FACEBOOK_URL || '#'

const navRowOne = PHOTO_CATEGORIES.slice(0, 10)
const navRowTwo = [...PHOTO_CATEGORIES.slice(10), ...STATIC_NAV_LINKS]

function navItemClasses(isActive: boolean) {
  return [
    'nav-link lowercase text-black hover:opacity-60 transition-opacity',
    isActive && 'underline underline-offset-[3px]',
  ]
}
---

<header class="pt-10 pb-6 px-4 text-center">
  <h1 class="text-[17px] font-normal tracking-normal text-black leading-tight">
    {photographerName}
  </h1>
  <p class="text-[15px] font-normal text-portfolio-muted mt-0.5 leading-tight">
    {photographerTitle}
  </p>

  <nav class="mt-5" aria-label="Portfolio-Kategorien">
    <ul class="flex flex-wrap justify-center items-center gap-x-1 gap-y-0 text-[13px] leading-relaxed">
      {
        navRowOne.map((cat, index) => (
          <>
            {index > 0 && (
              <li class="text-portfolio-muted select-none px-0.5" aria-hidden="true">
                ·
              </li>
            )}
            <li>
              <a
                href={`?category=${cat.value}`}
                data-category={cat.value}
                class:list={navItemClasses(activeCategory === cat.value)}
              >
                {cat.label}
              </a>
            </li>
          </>
        ))
      }
    </ul>

    <ul class="flex flex-wrap justify-center items-center gap-x-1 gap-y-0 text-[13px] leading-relaxed mt-0.5">
      {
        navRowTwo.map((item, index) => {
          const isCategory = 'value' in item
          const isActive = isCategory && activeCategory === item.value

          return (
            <>
              {index > 0 && (
                <li class="text-portfolio-muted select-none px-0.5" aria-hidden="true">
                  ·
                </li>
              )}
              <li>
                {
                  isCategory ? (
                    <a
                      href={`?category=${item.value}`}
                      data-category={item.value}
                      class:list={navItemClasses(isActive)}
                    >
                      {item.label}
                    </a>
                  ) : (
                    <a href={item.href} class="lowercase text-black hover:opacity-60 transition-opacity">
                      {item.label}
                    </a>
                  )
                }
              </li>
            </>
          )
        })
      }
    </ul>
  </nav>

  <div class="mt-4 flex justify-center items-center gap-3 text-portfolio-muted">
    <a
      href={facebookUrl}
      target={facebookUrl !== '#' ? '_blank' : undefined}
      rel={facebookUrl !== '#' ? 'noopener noreferrer' : undefined}
      aria-label="Facebook"
      class="hover:opacity-60 transition-opacity"
    >
      <svg class="w-[13px] h-[13px] fill-current" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
      </svg>
    </a>
    <a
      href={instagramUrl}
      target={instagramUrl !== '#' ? '_blank' : undefined}
      rel={instagramUrl !== '#' ? 'noopener noreferrer' : undefined}
      aria-label="Instagram"
      class="hover:opacity-60 transition-opacity"
    >
      <svg class="w-[13px] h-[13px] fill-current" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.227-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
      </svg>
    </a>
    <button
      type="button"
      id="share-button"
      class="text-[11px] lowercase hover:opacity-60 transition-opacity"
    >
      Share
    </button>
  </div>
</header>

<script>
  document.getElementById('share-button')?.addEventListener('click', async () => {
    const url = window.location.href

    if (navigator.share) {
      try {
        await navigator.share({ title: document.title, url })
      } catch {
        /* user cancelled */
      }
      return
    }

    await navigator.clipboard.writeText(url)
  })
</script>
