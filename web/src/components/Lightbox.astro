<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden bg-black"
  role="dialog"
  aria-modal="true"
  aria-label="Vollbildansicht"
  hidden
>
  <button
    type="button"
    id="lightbox-backdrop"
    class="absolute inset-0 w-full h-full cursor-default bg-black border-0 p-0"
    aria-label="Schließen"
  />

  <button
    type="button"
    id="lightbox-prev"
    class="absolute left-0 top-0 z-10 h-full w-1/4 border-0 bg-transparent p-0 opacity-0"
    aria-label="Vorheriges Bild"
    tabindex="-1"
  />

  <figure class="pointer-events-none absolute inset-0 z-[1] flex items-center justify-center p-0">
    <img
      id="lightbox-image"
      src=""
      alt=""
      class="max-h-full max-w-full select-none object-contain"
    />
  </figure>

  <button
    type="button"
    id="lightbox-next"
    class="absolute right-0 top-0 z-10 h-full w-1/4 border-0 bg-transparent p-0 opacity-0"
    aria-label="Nächstes Bild"
    tabindex="-1"
  />
</div>

<script>
  function initLightbox() {
    const lightbox = document.getElementById('lightbox')
    const image = document.getElementById('lightbox-image') as HTMLImageElement | null
    const backdrop = document.getElementById('lightbox-backdrop')
    const prevBtn = document.getElementById('lightbox-prev')
    const nextBtn = document.getElementById('lightbox-next')
    const grid = document.getElementById('photo-grid')

    if (!lightbox || !image || !grid) return

    let visibleItems: HTMLButtonElement[] = []
    let currentIndex = 0

    function getVisibleItems() {
      return Array.from(grid.querySelectorAll<HTMLButtonElement>('.photo-item')).filter(
        (item) => item.style.display !== 'none',
      )
    }

    function setHash(index: number) {
      const nextHash = `#e-${index + 1}`
      if (window.location.hash !== nextHash) {
        history.replaceState(null, '', nextHash)
      }
    }

    function clearHash() {
      if (window.location.hash.startsWith('#e-')) {
        history.replaceState(null, '', window.location.pathname + window.location.search)
      }
    }

    function open(index: number) {
      visibleItems = getVisibleItems()
      if (!visibleItems.length) return

      currentIndex = index
      const item = visibleItems[currentIndex]
      const full = item.dataset.full
      const title = item.dataset.title || ''

      if (!full) return

      image.src = full
      image.alt = title
      lightbox.hidden = false
      lightbox.classList.remove('hidden')
      document.body.style.overflow = 'hidden'
      setHash(currentIndex)
    }

    function close() {
      lightbox.hidden = true
      lightbox.classList.add('hidden')
      image.src = ''
      document.body.style.overflow = ''
      clearHash()
    }

    function show(delta: number) {
      if (!visibleItems.length) return
      currentIndex = (currentIndex + delta + visibleItems.length) % visibleItems.length
      const item = visibleItems[currentIndex]
      image.src = item.dataset.full || ''
      image.alt = item.dataset.title || ''
      setHash(currentIndex)
    }

    function openFromHash() {
      const match = window.location.hash.match(/^#e-(\d+)$/)
      if (!match) return

      visibleItems = getVisibleItems()
      const index = Number.parseInt(match[1], 10) - 1
      if (index >= 0 && index < visibleItems.length) {
        open(index)
      }
    }

    grid.addEventListener('click', (event) => {
      const target = (event.target as HTMLElement).closest<HTMLButtonElement>('.photo-item')
      if (!target) return

      visibleItems = getVisibleItems()
      const index = visibleItems.indexOf(target)
      if (index >= 0) open(index)
    })

    backdrop?.addEventListener('click', close)
    prevBtn?.addEventListener('click', (event) => {
      event.stopPropagation()
      show(-1)
    })
    nextBtn?.addEventListener('click', (event) => {
      event.stopPropagation()
      show(1)
    })

    document.addEventListener('keydown', (event) => {
      if (lightbox.hidden) return

      if (event.key === 'Escape') close()
      if (event.key === 'ArrowLeft') show(-1)
      if (event.key === 'ArrowRight') show(1)
    })

    window.addEventListener('hashchange', () => {
      if (window.location.hash.startsWith('#e-')) {
        openFromHash()
      } else if (!lightbox.hidden) {
        close()
      }
    })

    openFromHash()
  }

  initLightbox()
  document.addEventListener('astro:page-load', initLightbox)
</script>
