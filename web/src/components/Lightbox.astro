<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden bg-black"
  role="dialog"
  aria-modal="true"
  aria-label="Vollbildansicht"
  hidden
>
  <button
    type="button"
    id="lightbox-backdrop"
    class="absolute inset-0 w-full h-full cursor-default bg-black border-0 p-0"
    aria-label="Schließen"
  />

  <button
    type="button"
    id="lightbox-prev"
    class="absolute left-0 top-0 z-10 h-full w-1/4 border-0 bg-transparent p-0 opacity-0"
    aria-label="Vorheriges Bild"
    tabindex="-1"
  />

  <figure class="pointer-events-none absolute inset-0 z-[1] flex items-center justify-center p-4 md:p-8">
    <img
      id="lightbox-image"
      src=""
      alt=""
      class="max-h-full max-w-full select-none object-contain"
    />
  </figure>

  <button
    type="button"
    id="lightbox-next"
    class="absolute right-0 top-0 z-10 h-full w-1/4 border-0 bg-transparent p-0 opacity-0"
    aria-label="Nächstes Bild"
    tabindex="-1"
  />
</div>

<script>
  function initLightbox() {
    const lightbox = document.getElementById('lightbox')
    const image = document.getElementById('lightbox-image')
    const backdrop = document.getElementById('lightbox-backdrop')
    const prevBtn = document.getElementById('lightbox-prev')
    const nextBtn = document.getElementById('lightbox-next')

    if (!lightbox || !image) return

    let activeItems = []
    let currentIndex = 0

    function getItemsInGroup(group) {
      if (!group) return []
      return Array.from(group.querySelectorAll('.lightbox-item'))
    }

    function setHash(index) {
      const nextHash = `#e-${index + 1}`
      if (window.location.hash !== nextHash) {
        history.replaceState(null, '', nextHash)
      }
    }

    function clearHash() {
      if (window.location.hash.startsWith('#e-')) {
        history.replaceState(null, '', window.location.pathname + window.location.search)
      }
    }

    function open(index) {
      if (!activeItems.length) return

      currentIndex = index
      const item = activeItems[currentIndex]
      const full = item.dataset.full
      const title = item.dataset.title || ''

      if (!full) return

      image.src = full
      image.alt = title
      lightbox.hidden = false
      lightbox.classList.remove('hidden')
      document.body.style.overflow = 'hidden'
      setHash(currentIndex)
    }

    function close() {
      lightbox.hidden = true
      lightbox.classList.add('hidden')
      image.src = ''
      image.alt = ''
      document.body.style.overflow = ''
      clearHash()
      activeItems = []
    }

    function show(delta) {
      if (!activeItems.length) return
      currentIndex = (currentIndex + delta + activeItems.length) % activeItems.length
      const item = activeItems[currentIndex]
      image.src = item.dataset.full || ''
      image.alt = item.dataset.title || ''
      setHash(currentIndex)
    }

    function openFromHash() {
      const match = window.location.hash.match(/^#e-(\d+)$/)
      if (!match) return

      const groups = document.querySelectorAll('[data-lightbox-group]')
      for (const group of groups) {
        const items = getItemsInGroup(group)
        const index = Number.parseInt(match[1], 10) - 1
        if (index >= 0 && index < items.length) {
          activeItems = items
          open(index)
          return
        }
      }
    }

    if (!window.__lightboxBound) {
      window.__lightboxBound = true

      document.addEventListener('click', (event) => {
        const target = event.target.closest('.lightbox-item')
        if (!target) return

        const group = target.closest('[data-lightbox-group]')
        activeItems = getItemsInGroup(group)
        const index = activeItems.indexOf(target)
        if (index >= 0) open(index)
      })

      backdrop?.addEventListener('click', close)
      prevBtn?.addEventListener('click', (event) => {
        event.stopPropagation()
        show(-1)
      })
      nextBtn?.addEventListener('click', (event) => {
        event.stopPropagation()
        show(1)
      })

      document.addEventListener('keydown', (event) => {
        if (lightbox.hidden) return

        if (event.key === 'Escape') close()
        if (event.key === 'ArrowLeft') show(-1)
        if (event.key === 'ArrowRight') show(1)
      })

      window.addEventListener('hashchange', () => {
        if (window.location.hash.startsWith('#e-')) {
          openFromHash()
        } else if (!lightbox.hidden) {
          close()
        }
      })
    }

    openFromHash()
  }

  initLightbox()
  document.addEventListener('astro:page-load', initLightbox)
</script>
