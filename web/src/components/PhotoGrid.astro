---
const payloadUrl = (import.meta.env.PUBLIC_PAYLOAD_URL || 'http://localhost:3000').replace(/\/$/, '')
---

<div
  id="photo-grid"
  class="grid grid-cols-2 md:grid-cols-4 gap-[2px] auto-rows-[minmax(140px,1fr)] md:auto-rows-[200px]"
></div>

<p
  id="photo-grid-loading"
  class="py-24 text-center text-[13px] text-portfolio-muted"
>
  Fotografien werden geladen…
</p>

<p
  id="photo-grid-empty"
  class="hidden py-24 text-center text-[13px] text-portfolio-muted"
>
  Noch keine Fotografien vorhanden. Bitte im{' '}
  <a href={`${payloadUrl}/admin`} class="underline">
    Admin-Panel
  </a>{' '}
  Bilder hochladen.
</p>

<p
  id="photo-grid-error"
  class="hidden py-24 text-center text-[13px] text-red-700"
  role="alert"
></p>

<script>
  import { loadPhotoGrid } from '../lib/photoLoader'

  loadPhotoGrid()
  document.addEventListener('astro:page-load', () => loadPhotoGrid())
</script>
