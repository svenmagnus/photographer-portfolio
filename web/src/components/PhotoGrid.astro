---
import type { Photo } from '../lib/payload'
import { getMediaUrl } from '../lib/payload'

interface Props {
  photos: Photo[]
}

const { photos } = Astro.props
---

<div
  id="photo-grid"
  class="grid grid-cols-2 md:grid-cols-4 gap-[2px] auto-rows-[minmax(140px,1fr)] md:auto-rows-[200px]"
>
  {
    photos.map((photo, index) => {
      const media = typeof photo.image === 'object' ? photo.image : null
      const gridUrl = getMediaUrl(media, 'grid')
      const fullUrl = getMediaUrl(media, 'fullscreen') || getMediaUrl(media)
      const alt = media?.alt || photo.title
      const isPortrait = media?.height && media?.width ? media.height > media.width * 1.15 : false
      const isFeatured = photo.featured || isPortrait

      return (
        <button
          type="button"
          class:list={[
            'photo-item relative block h-full min-h-0 w-full overflow-hidden bg-white p-0 border-0 cursor-pointer focus:outline-none',
            isFeatured ? 'row-span-2' : 'row-span-1',
          ]}
          data-index={index}
          data-full={fullUrl}
          data-title={photo.title}
          data-category={photo.category}
          aria-label={`${photo.title} öffnen`}
        >
          {
            gridUrl ? (
              <img
                src={gridUrl}
                alt={alt}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 h-full w-full object-cover"
              />
            ) : (
              <div class="flex h-full min-h-[140px] items-center justify-center text-[13px] text-portfolio-muted">
                Kein Bild
              </div>
            )
          }
        </button>
      )
    })
  }
</div>

{
  photos.length === 0 && (
    <p class="py-24 text-center text-[13px] text-portfolio-muted">
      Noch keine Fotografien vorhanden. Bitte im{' '}
      <a href={`${import.meta.env.PUBLIC_PAYLOAD_URL}/admin`} class="underline">
        Admin-Panel
      </a>{' '}
      Bilder hochladen.
    </p>
  )
}
