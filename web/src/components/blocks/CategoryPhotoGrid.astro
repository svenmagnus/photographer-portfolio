---
import type { PhotoCategory } from '../../lib/categories'
import type { Locale } from '../../i18n/locale'
import { DEFAULT_LOCALE } from '../../i18n/locale'
import { t } from '../../i18n/messages'

interface Props {
  category: PhotoCategory
  rootId: string
  locale?: Locale
}

const { category, rootId, locale = DEFAULT_LOCALE } = Astro.props
---

<div
  id={`${rootId}-grid`}
  data-lightbox-group={rootId}
  class="photo-grid"
></div>

<p
  id={`${rootId}-loading`}
  class="py-12 text-center text-[13px] text-portfolio-muted"
>
  {t(locale, 'photoGridLoading')}
</p>

<p
  id={`${rootId}-empty`}
  class="hidden py-12 text-center text-[13px] text-portfolio-muted"
>
  {t(locale, 'photoGridEmptyCategory')}
</p>

<p
  id={`${rootId}-error`}
  class="hidden py-12 text-center text-[13px] text-red-700"
  role="alert"
></p>

<script define:vars={{ category, rootId }}>
  import { loadCategoryPhotoGrid } from '../../lib/photoLoader'

  loadCategoryPhotoGrid(category, rootId)
</script>
