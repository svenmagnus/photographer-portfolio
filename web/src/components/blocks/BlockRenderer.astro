---
import type { PageBlock } from '../../lib/pages'
import { lexicalToHtml } from '../../lib/lexicalToHtml'
import { getMediaUrl, getFullMediaUrl, type Media } from '../../lib/photoLoader'
import type { SiteSettingsData } from '../../lib/siteSettings'
import { getVideoEmbedUrl, getAspectRatioClass } from '../../lib/videoEmbed'
import CategoryPhotoGrid from './CategoryPhotoGrid.astro'
import ContactForm from './ContactForm.astro'
import ModelApplicationForm from './ModelApplicationForm.astro'

interface Props {
  blocks: PageBlock[]
  pageType?: 'content' | 'gallery' | 'landing' | 'blog'
  settings?: SiteSettingsData
  locale?: import('../i18n/locale').Locale
}

const { blocks, pageType = 'content', settings } = Astro.props

function isMedia(value: unknown): value is Media {
  return Boolean(value && typeof value === 'object' && 'id' in value)
}

function getWidthClass(width?: string | null): string {
  switch (width) {
    case 'narrow':
      return 'max-w-prose'
    case 'full':
      return 'max-w-none w-full'
    case 'normal':
    default:
      return 'max-w-3xl'
  }
}

function getSpacerClass(size?: string | null): string {
  switch (size) {
    case 'small':
      return 'h-6 md:h-8'
    case 'large':
      return 'h-16 md:h-24'
    case 'medium':
    default:
      return 'h-10 md:h-14'
  }
}

function getGalleryCols(columns?: string | null): string {
  switch (columns) {
    case '2':
      return 'content-gallery-grid content-gallery-grid--max-2'
    case '3':
      return 'content-gallery-grid content-gallery-grid--max-3'
    case '4':
    default:
      return 'content-gallery-grid'
  }
}

function getMediaTextLayout(
  layout?: string | null,
  imageWidth?: string | null,
): { container: string; image: string; text: string } {
  if (layout === 'stacked') {
    return {
      container: 'flex flex-col gap-8',
      image: 'w-full',
      text: 'w-full',
    }
  }

  const imageBasis =
    imageWidth === 'third'
      ? 'md:basis-1/3'
      : imageWidth === 'twoThirds'
        ? 'md:basis-2/3'
        : 'md:basis-1/2'

  return {
    container: `flex flex-col gap-8 md:flex-row md:items-start ${layout === 'imageRight' ? 'md:flex-row-reverse' : ''}`,
    image: `w-full shrink-0 ${imageBasis}`,
    text: 'w-full flex-1',
  }
}

function getGalleryEntryMedia(entry: unknown): Media | null {
  if (isMedia(entry)) return entry
  if (entry && typeof entry === 'object' && 'image' in entry) {
    const image = (entry as { image?: unknown }).image
    return isMedia(image) ? image : null
  }
  return null
}

function getGalleryEntryCaption(entry: unknown): string | null {
  if (entry && typeof entry === 'object' && 'caption' in entry) {
    const caption = (entry as { caption?: string | null }).caption
    return caption || null
  }
  return null
}

const sectionWidth = pageType === 'landing' ? 'max-w-[1400px]' : 'max-w-5xl'
---

<div class={`page-content mx-auto px-4 md:px-6 ${sectionWidth}`}>
  {
    blocks.map((block, index) => {
      if (block.blockType === 'heading') {
        const Tag = block.level === 'h2' ? 'h2' : 'h1'
        const align = block.align === 'left' ? 'text-left' : 'text-center'
        return (
          <section class={`py-6 ${align}`}>
            <Tag class="font-normal tracking-tight text-black text-[clamp(1.75rem,4vw,2.75rem)] leading-tight">
              {block.text}
            </Tag>
          </section>
        )
      }

      if (block.blockType === 'richText') {
        const html = lexicalToHtml(block.content)
        return (
          <section class={`py-4 mx-auto ${getWidthClass(block.width)}`}>
            <div class="cms-rich-text" set:html={html} />
          </section>
        )
      }

      if (block.blockType === 'mediaText' && isMedia(block.image)) {
        const html = lexicalToHtml(block.content)
        const layout = getMediaTextLayout(block.layout, block.imageWidth)
        const src = getMediaUrl(block.image)

        return (
          <section class="py-10">
            <div class={`${layout.container} md:gap-12`}>
              <div class={layout.image}>
                {
                  src ? (
                    <img
                      src={src}
                      alt={block.image.alt || ''}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-auto object-cover"
                    />
                  ) : null
                }
              </div>
              <div class={layout.text}>
                <div class="cms-rich-text" set:html={html} />
              </div>
            </div>
          </section>
        )
      }

      if (block.blockType === 'imageGallery' && block.images?.length) {
        const fullWidth = block.fullWidth !== false
        const galleryId = `gallery-${index}`
        return (
          <section class={`py-4 ${fullWidth ? 'gallery-full-bleed' : ''}`}>
            <div
              class={getGalleryCols(block.columns)}
              data-lightbox-group={galleryId}
            >
              {
                block.images.map((entry) => {
                  const media = getGalleryEntryMedia(entry)
                  const src = getMediaUrl(media)
                  const fullSrc = getFullMediaUrl(media)
                  if (!src) return null
                  const caption = getGalleryEntryCaption(entry)
                  const alt = media?.alt || caption || ''

                  return (
                    <figure class="relative overflow-hidden bg-neutral-100">
                      <button
                        type="button"
                        class="lightbox-item block w-full cursor-zoom-in border-0 bg-transparent p-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-black/30"
                        data-full={fullSrc || src}
                        data-title={alt}
                        aria-label={`${alt} vergrößern`}
                      >
                        <img
                          src={src}
                          alt={alt}
                          loading="lazy"
                          decoding="async"
                          class:list={[
                            'block w-full pointer-events-none',
                            fullWidth ? 'h-auto object-contain' : 'h-full object-cover',
                          ]}
                        />
                      </button>
                      {
                        caption ? (
                          <figcaption class="px-2 py-2 text-[11px] text-portfolio-muted text-center">
                            {caption}
                          </figcaption>
                        ) : null
                      }
                    </figure>
                  )
                })
              }
            </div>
          </section>
        )
      }

      if (block.blockType === 'photoGrid') {
        const gridId = `page-grid-${index}`
        return (
          <section class="py-4">
            {block.showTitle ? <h2 class="mb-4 text-center text-xl">{block.category}</h2> : null}
            <CategoryPhotoGrid category={block.category} rootId={gridId} />
          </section>
        )
      }

      if (block.blockType === 'video') {
        const embedUrl = getVideoEmbedUrl(block.url)
        const posterMedia = isMedia(block.poster) ? block.poster : null
        const posterUrl = getMediaUrl(posterMedia)

        return (
          <section class="py-8 max-w-4xl mx-auto">
            {
              embedUrl ? (
                <div class={`relative w-full overflow-hidden bg-black ${getAspectRatioClass(block.aspectRatio)}`}>
                  <iframe
                    src={embedUrl}
                    title={block.caption || 'Video'}
                    class="absolute inset-0 h-full w-full border-0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  />
                </div>
              ) : posterUrl ? (
                <img src={posterUrl} alt={block.caption || 'Video'} class="w-full h-auto" loading="lazy" />
              ) : (
                <p class="text-center text-[13px] text-portfolio-muted">
                  <a href={block.url} class="underline" target="_blank" rel="noopener noreferrer">
                    Video öffnen
                  </a>
                </p>
              )
            }
            {block.caption ? <p class="mt-3 text-center text-[13px] text-portfolio-muted">{block.caption}</p> : null}
          </section>
        )
      }

      if (block.blockType === 'spacer') {
        return <div class={getSpacerClass(block.size)} aria-hidden="true" />
      }

      if (block.blockType === 'contactForm') {
        const email = settings?.contactEmail || settings?.professionalEmail
        const phone = settings?.contactPhone

        return (
          <ContactForm
            blockId={String(index)}
            intro={block.intro}
            showPhone={block.showPhone}
            showEmail={block.showEmail}
            submitLabel={block.submitLabel}
            successMessage={block.successMessage}
            email={email}
            phone={phone}
          />
        )
      }

      if (block.blockType === 'modelApplicationForm') {
        return (
          <ModelApplicationForm
            blockId={String(index)}
            intro={block.intro}
            privacyUrl={block.privacyUrl}
            submitLabel={block.submitLabel}
            successMessage={block.successMessage}
          />
        )
      }

      if (block.blockType === 'contactInfo') {
        const email = settings?.contactEmail || settings?.professionalEmail
        const align = block.align === 'left' ? 'text-left' : 'text-center'
        const socialAlign =
          block.align === 'left' ? 'justify-start' : 'justify-center'

        return (
          <section class={`py-4 max-w-2xl mx-auto text-[15px] leading-relaxed ${align}`}>
            {
              email ? (
                <p>
                  <a href={`mailto:${email}`} class="underline hover:opacity-60 transition-opacity">
                    {email}
                  </a>
                </p>
              ) : (
                <p class="text-portfolio-muted">
                  E-Mail unter Website-Einstellungen → Kontakt & Social hinterlegen.
                </p>
              )
            }
            {
              block.showSocial !== false && (settings?.instagramUrl || settings?.facebookUrl) ? (
                <div class={`mt-4 flex flex-wrap gap-4 text-[13px] ${socialAlign}`}>
                  {
                    settings?.instagramUrl ? (
                      <a
                        href={settings.instagramUrl}
                        class="underline hover:opacity-60 transition-opacity"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        Instagram
                      </a>
                    ) : null
                  }
                  {
                    settings?.facebookUrl ? (
                      <a
                        href={settings.facebookUrl}
                        class="underline hover:opacity-60 transition-opacity"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        Facebook
                      </a>
                    ) : null
                  }
                </div>
              ) : null
            }
          </section>
        )
      }

      return null
    })
  }
</div>

<style>
  .gallery-full-bleed {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }
</style>
