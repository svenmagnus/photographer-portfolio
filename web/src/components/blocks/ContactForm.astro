---
import { lexicalToHtml } from '../../lib/lexicalToHtml'
import type { Locale } from '../../i18n/locale'
import { DEFAULT_LOCALE } from '../../i18n/locale'
import { contactIntroHtml } from '../../i18n/pageLabels'
import { t } from '../../i18n/messages'

interface Props {
  blockId: string
  intro?: Record<string, unknown> | null
  showPhone?: boolean | null
  showEmail?: boolean | null
  submitLabel?: string | null
  successMessage?: string | null
  email?: string | null
  phone?: string | null
  locale?: Locale
  pageSlug?: string
}

const {
  blockId,
  intro,
  showPhone = true,
  showEmail = true,
  submitLabel,
  successMessage,
  email,
  phone,
  locale = DEFAULT_LOCALE,
  pageSlug,
} = Astro.props

const introHtml = intro ? lexicalToHtml(intro) : ''
const payloadUrl = (import.meta.env.PUBLIC_PAYLOAD_URL || 'http://localhost:3000').replace(/\/$/, '')
const formId = `contact-form-${blockId}`

const resolvedSubmitLabel = submitLabel || t(locale, 'contactDefaultSubmit')
const resolvedSuccessMessage = successMessage || t(locale, 'contactDefaultSuccess')
const displayIntroHtml =
  introHtml || (pageSlug === 'contact' ? contactIntroHtml(locale) : '')
const labels = {
  phone: t(locale, 'contactPhoneLabel'),
  email: t(locale, 'contactEmailLabel'),
  name: t(locale, 'contactNamePlaceholder'),
  emailField: t(locale, 'contactEmailPlaceholder'),
  message: t(locale, 'contactMessagePlaceholder'),
  requiredFields: t(locale, 'contactRequiredFields'),
  sending: t(locale, 'contactSending'),
  sendError: t(locale, 'contactSendError'),
}
---

<section class="py-8 max-w-3xl mx-auto">
  {
    displayIntroHtml ? (
      <div
        class="cms-rich-text mb-10 text-center md:text-left"
        set:html={displayIntroHtml}
      />
    ) : null
  }

  <div class="grid gap-12 md:grid-cols-2 md:items-start">
    <div class="space-y-8 text-[15px] leading-relaxed text-black">
      {
        showPhone !== false && phone ? (
          <div>
            <p class="font-semibold mb-1">{labels.phone}</p>
            <p>
              <a href={`tel:${phone.replace(/\s/g, '')}`} class="hover:opacity-60 transition-opacity">
                {phone}
              </a>
            </p>
          </div>
        ) : null
      }
      {
        showEmail !== false && email ? (
          <div>
            <p class="font-semibold mb-1">{labels.email}</p>
            <p>
              <a href={`mailto:${email}`} class="hover:opacity-60 transition-opacity">
                {email}
              </a>
            </p>
          </div>
        ) : null
      }
    </div>

    <form id={formId} class="contact-form space-y-0" novalidate>
      <label class="sr-only" for={`${formId}-name`}>{labels.name}</label>
      <input
        id={`${formId}-name`}
        type="text"
        name="name"
        placeholder={labels.name}
        required
        autocomplete="name"
        class="contact-field"
      />

      <label class="sr-only" for={`${formId}-email`}>{labels.emailField}</label>
      <input
        id={`${formId}-email`}
        type="email"
        name="email"
        placeholder={labels.emailField}
        required
        autocomplete="email"
        class="contact-field"
      />

      <label class="sr-only" for={`${formId}-message`}>{labels.message}</label>
      <textarea
        id={`${formId}-message`}
        name="message"
        placeholder={labels.message}
        required
        rows="6"
        class="contact-field contact-field-textarea"
      />

      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        class="hidden"
        aria-hidden="true"
      />

      <button type="submit" class="contact-submit">
        {resolvedSubmitLabel}
      </button>

      <p class="contact-status hidden mt-4 text-[13px]" role="status" aria-live="polite" />
    </form>
  </div>
</section>

<script define:vars={{ formId, payloadUrl, resolvedSuccessMessage, labels, resolvedSubmitLabel }}>
  const form = document.getElementById(formId)
  if (!form) throw new Error('Contact form not found')

  const statusEl = form.querySelector('.contact-status')
  const submitBtn = form.querySelector('.contact-submit')

  form.addEventListener('submit', async (event) => {
    event.preventDefault()

    if (!(submitBtn instanceof HTMLButtonElement) || !(statusEl instanceof HTMLElement)) return

    const formData = new FormData(form)
    const name = String(formData.get('name') || '').trim()
    const email = String(formData.get('email') || '').trim()
    const message = String(formData.get('message') || '').trim()
    const website = String(formData.get('website') || '').trim()

    statusEl.classList.remove('hidden', 'text-red-700', 'text-black')
    statusEl.textContent = ''

    if (!name || !email || !message) {
      statusEl.textContent = labels.requiredFields
      statusEl.classList.add('text-red-700')
      return
    }

    submitBtn.disabled = true
    submitBtn.textContent = labels.sending

    try {
      const response = await fetch(`${payloadUrl}/api/contact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message, website }),
      })

      const data = await response.json().catch(() => ({}))

      if (!response.ok) {
        throw new Error(data.error || labels.sendError)
      }

      form.reset()
      statusEl.textContent = resolvedSuccessMessage
      statusEl.classList.add('text-black')
    } catch (error) {
      statusEl.textContent =
        error instanceof Error ? error.message : labels.sendError
      statusEl.classList.add('text-red-700')
    } finally {
      submitBtn.disabled = false
      submitBtn.textContent = submitBtn.dataset.label || resolvedSubmitLabel
      statusEl.classList.remove('hidden')
    }
  })

  if (submitBtn instanceof HTMLButtonElement) {
    submitBtn.dataset.label = submitBtn.textContent || resolvedSubmitLabel
  }
</script>

<style>
  .contact-field {
    display: block;
    width: 100%;
    border: 1px solid #d4d4d4;
    border-bottom: none;
    background: #fff;
    padding: 0.85rem 1rem;
    font-size: 15px;
    line-height: 1.4;
    color: #000;
    outline: none;
    resize: vertical;
    font-family: inherit;
  }

  .contact-field:first-of-type {
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }

  .contact-field-textarea {
    border-bottom: 1px solid #d4d4d4;
    min-height: 9rem;
  }

  .contact-field:focus {
    border-color: #a3a3a3;
    z-index: 1;
    position: relative;
  }

  .contact-field::placeholder {
    color: #a3a3a3;
  }

  .contact-submit {
    margin-top: 1rem;
    width: 100%;
    border: 1px solid #d4d4d4;
    background: #fff;
    padding: 0.85rem 1rem;
    font-size: 15px;
    color: #000;
    cursor: pointer;
    font-family: inherit;
    transition: opacity 0.15s ease;
  }

  .contact-submit:hover:not(:disabled) {
    opacity: 0.7;
  }

  .contact-submit:disabled {
    opacity: 0.5;
    cursor: wait;
  }
</style>
